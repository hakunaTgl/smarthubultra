# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456

# SendGrid (Email)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=no-reply@smarthubultra.dev

# Admin Configuration
ADMIN_MANUAL_SECRET=your_admin_secret_here

# Application URLs
APP_SIGNIN_URL=https://smarthubultra.web.app
FUNCTIONS_BASE_URL=https://us-central1-your-project.cloudfunctions.net

# Cleanup Configuration (milliseconds)
CLEANUP_GUEST_TTL_MS=172800000
CLEANUP_SESSION_TTL_MS=172800000
CLEANUP_PROJECT_TTL_MS=604800000

# Environment
NODE_ENV=development

# Optional: Third-party Integrations
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# REPLICATE_API_TOKEN=...
